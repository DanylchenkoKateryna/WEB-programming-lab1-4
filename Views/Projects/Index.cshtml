@model IEnumerable<lab1_4.Models.Project>
@{ ViewData["Title"] = "Projects"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Projects</h1>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-success">+ New Project</a>
    }
</div>

<div class="row g-3">
    @foreach (var p in Model)
    {
        var badgeColor = p.Status switch {
            lab1_4.Models.ProjectStatus.Active => "success",
            lab1_4.Models.ProjectStatus.Completed => "secondary",
            lab1_4.Models.ProjectStatus.OnHold => "warning",
            lab1_4.Models.ProjectStatus.Cancelled => "danger",
            _ => "info"
        };
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header d-flex justify-content-between">
                    <span class="badge bg-@badgeColor">@p.Status</span>
                    <span class="badge bg-dark">@p.Priority</span>
                </div>
                <div class="card-body">
                    <h5 class="card-title">@p.Name</h5>
                    <p class="card-text text-muted small">@(p.Description.Length > 80 ? p.Description[..80] + "…" : p.Description)</p>
                    <p class="card-text"><small>Team: @p.EmployeeProjects.Count members</small></p>
                    @if (p.Budget > 0)
                    {
                        <p class="card-text"><small>Budget: @p.Budget.ToString("C")</small></p>
                    }
                </div>
                <div class="card-footer d-flex gap-2 flex-wrap">
                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">Details</a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Chat" asp-action="Index" asp-route-projectId="@p.Id" class="btn btn-sm btn-outline-info">Chat</a>
                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    }
                </div>
            </div>
        </div>
    }
</div>
