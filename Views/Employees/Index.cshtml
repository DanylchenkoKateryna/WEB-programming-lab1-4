@model IEnumerable<lab1_4.Models.Employee>
@{ ViewData["Title"] = "Employees"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Employees</h1>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-primary">+ Add Employee</a>
    }
</div>

<div class="row g-3">
    @foreach (var e in Model)
    {
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">@e.FullName</h5>
                    <p class="card-text text-muted">@e.Position · @e.Department</p>
                    <p class="card-text"><small>@e.Email</small></p>
                    <p class="card-text"><small class="text-muted">Projects: @e.EmployeeProjects.Count</small></p>
                </div>
                <div class="card-footer d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@e.Id" class="btn btn-sm btn-outline-primary">Details</a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@e.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    }
                </div>
            </div>
        </div>
    }
</div>
