@model lab1_4.Models.ViewModels.ChangeRoleViewModel
@{ ViewData["Title"] = "Edit Roles"; }

<h1>Edit Roles for @Model.UserName</h1>
<form asp-action="EditRole" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="userId" value="@Model.UserId" />
    <div class="mb-3">
        @foreach (var role in Model.AllRoles)
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="roles" value="@role"
                       id="role_@role" @(Model.UserRoles.Contains(role) ? "checked" : "") />
                <label class="form-check-label" for="role_@role">@role</label>
            </div>
        }
    </div>
    <button type="submit" class="btn btn-primary">Save Roles</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
