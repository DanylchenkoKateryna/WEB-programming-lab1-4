@model IEnumerable<lab1_4.Models.ViewModels.AdminUserViewModel>
@{ ViewData["Title"] = "Admin Panel"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Admin Panel — User Management</h1>
    <div class="d-flex gap-2">
        <a asp-controller="Employees" asp-action="Index" class="btn btn-outline-primary">Manage Employees</a>
        <a asp-controller="Projects" asp-action="Index" class="btn btn-outline-success">Manage Projects</a>
    </div>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Display Name</th>
            <th>Email</th>
            <th>Roles</th>
            <th>Linked Employee</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.DisplayName</td>
                <td>@user.Email</td>
                <td>
                    @foreach (var role in user.Roles)
                    {
                        <span class="badge @(role == "Admin" ? "bg-danger" : "bg-secondary") me-1">@role</span>
                    }
                </td>
                <td>
                    @if (user.LinkedEmployeeId.HasValue)
                    {
                        <a asp-controller="Employees" asp-action="Details" asp-route-id="@user.LinkedEmployeeId">
                            @user.LinkedEmployeeName
                        </a>
                    }
                    else
                    {
                        <span class="text-muted">Not linked</span>
                    }
                </td>
                <td>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-action="EditRole" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Roles</a>
                        <button class="btn btn-sm btn-outline-secondary"
                                data-bs-toggle="modal"
                                data-bs-target="#linkModal"
                                data-userid="@user.Id"
                                data-username="@user.DisplayName"
                                data-linkedid="@(user.LinkedEmployeeId?.ToString() ?? "")">
                            Link Employee
                        </button>
                        <form asp-action="DeleteUser" method="post" onsubmit="return confirm('Delete user @user.UserName?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Link Employee Modal -->
<div class="modal fade" id="linkModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="LinkEmployee" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" id="modalUserId" />
                <div class="modal-header">
                    <h5 class="modal-title">Link Employee to <span id="modalUserName"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label">Select Employee</label>
                    <select name="employeeId" class="form-select">
                        <option value="">— None (unlink) —</option>
                        @foreach (var emp in (IEnumerable<lab1_4.Models.Employee>)ViewBag.AllEmployees ?? Enumerable.Empty<lab1_4.Models.Employee>())
                        {
                            <option value="@emp.Id">@emp.FullName (@emp.Position)</option>
                        }
                    </select>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('linkModal').addEventListener('show.bs.modal', function(e) {
    const btn = e.relatedTarget;
    document.getElementById('modalUserId').value = btn.dataset.userid;
    document.getElementById('modalUserName').textContent = btn.dataset.username;
    const sel = document.querySelector('#linkModal select[name=employeeId]');
    sel.value = btn.dataset.linkedid || "";
});
</script>
}
