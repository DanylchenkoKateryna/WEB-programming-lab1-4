@model IEnumerable<lab1_4.Models.ViewModels.AdminUserViewModel>
@{ ViewData["Title"] = "Admin Panel"; }

<h1>Admin Panel — User Management</h1>
<table class="table table-striped table-hover mt-4">
    <thead class="table-dark">
        <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Roles</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>
                    @foreach (var role in user.Roles)
                    {
                        <span class="badge @(role == "Admin" ? "bg-danger" : "bg-secondary") me-1">@role</span>
                    }
                </td>
                <td class="d-flex gap-2">
                    <a asp-action="EditRole" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Edit Roles</a>
                    <form asp-action="DeleteUser" method="post" onsubmit="return confirm('Delete this user?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@user.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
